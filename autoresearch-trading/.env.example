# LLM Configuration (OpenRouter only)
OPENROUTER_API_KEY=sk-or-v1-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
LLM_MODEL=minimax/minimax-m1

# MT5 (Forex/Gold)
MT5_LOGIN=123456
MT5_PASSWORD=your_password_here
MT5_SERVER=Broker-Demo

# System
MODE=paper
MAX_DAILY_LOSS_PCT=0.02
MAX_POSITION_PCT=0.05
MAX_LOSS_PCT=0.02

# Walk-Forward Validation
WFV_N_WINDOWS=6
WFV_TRAIN_BARS=3000
WFV_TEST_BARS=1000
WFV_STEP_BARS=1000

# Agent
EXPERIMENT_COOLDOWN=60
MIN_EXPERIMENTS_FOR_LIVE=50
MIN_SHARPE_FOR_LIVE=1.0
MAX_DRAWDOWN_FOR_LIVE=0.10