# ============================================
# AUTORESEARCH TRADING - CONFIGURATION
# ============================================
# Copiar este archivo a .env y completar los valores
# NUNCA commitear .env a git

# ============================================
# LLM Configuration (requerido)
# ============================================
# OpenRouter (único backend soportado)
OPENROUTER_API_KEY=sk-or-your-key-here

# Modelo a usar: minimax/minimax-m1, thudm/glm-4-plus (modelos gratuitos)
LLM_MODEL=minimax/minimax-m1

# ============================================
# MetaTrader 5 (requerido para forex/gold)
# ============================================
MT5_LOGIN=12345678
MT5_PASSWORD=your_mt5_password
MT5_SERVER=YourBroker-Demo  # o "YourBroker" para live

# ============================================
# System Configuration
# ============================================
# Modo de operación: "paper" (simulado) o "live" (real)
MODE=paper

# Máximo pérdida diaria como fracción del capital (0.02 = 2%)
MAX_DAILY_LOSS_PCT=0.02

# ============================================
# Walk-Forward Validation
# ============================================
# Número de ventanas deslizantes
WFV_N_WINDOWS=6

# Barras M15 por ventana de entrenamiento (~31 días por defecto)
WFV_TRAIN_BARS=3000

# Barras M15 por ventana de test (~10 días por defecto)
WFV_TEST_BARS=1000

# Desplazamiento entre ventanas (~10 días por defecto)
WFV_STEP_BARS=1000
